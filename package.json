{
  "name": "workbee",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names web,electron \"npm run client\" \"wait-on http://localhost:9229 && npm run electron\"",
    "client": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "prepack": "rimraf build-output && npm run build",
    "pack": "electron-builder --dir",
    "pack:win": "node scripts/pack-win.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@tiptap/extension-image": "^3.15.3",
    "@tiptap/extension-link": "^3.15.3",
    "@tiptap/extension-placeholder": "^3.15.3",
    "@tiptap/extension-task-item": "^3.17.1",
    "@tiptap/extension-task-list": "^3.17.1",
    "@tiptap/react": "^3.15.3",
    "@tiptap/starter-kit": "^3.15.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "concurrently": "^9.2.1",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "rcedit": "^5.0.2",
    "rimraf": "^5.0.5",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "productName": "WorkerBee",
    "appId": "com.workbee.app",
    "asar": true,
    "files": [
      "package.json",
      "main.js",
      "electron/**",
      "dist/**",
      "database.ts",
      "logo.png",
      "favicon.ico"
    ],
    "directories": {
      "output": "build-output"
    },
    "win": {
      "target": "dir",
      "icon": "favicon.ico"
    },
    "linux": {
      "target": "dir"
    },
    "extraResources": []
  }
}
